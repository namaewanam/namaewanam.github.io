# pnpm configuration
# https://pnpm.io/npmrc

# Strictness
# Only allow packages declared in package.json (no phantom deps)
node-linker=hoisted
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@commitlint/*

# Fail if lockfile is outdated — prevents drift in CI
frozen-lockfile=false

# Performance
# Use the global store for deduplication across projects
# store-dir defaults to ~/.pnpm-store

# Prefer offline installs when cache is warm
prefer-frozen-lockfile=true

# Security
# Audit on install (uncomment to enforce — slows CI slightly)
# audit=true

# Reject packages with known vulnerabilities at install time
# (manual: run `pnpm audit` in CI)

# Engines
engine-strict=true

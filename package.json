{
	"name": "namaewanam.github.io",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@9.15.4",
	"engines": {
		"node": ">=20.0.0",
		"pnpm": ">=9.0.0"
	},
	"scripts": {
		"dev": "next dev --turbopack",
		"generate:resources": "tsx scripts/generate-feeds.ts",
		"predev": "pnpm generate:resources",
		"build:feeds": "pnpm generate:resources",
		"prebuild": "pnpm generate:resources",
		"build": "next build",
		"analyze": "ANALYZE=true pnpm build",
		"check:links": "tsx scripts/check-static-links.ts",
		"check:feeds": "tsx scripts/verify-feeds.ts",
		"start": "next start",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
		"format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
		"type-check": "tsc --noEmit",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"eslint --fix"
		],
		"*.{js,jsx,ts,tsx,json,css,md}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@giscus/react": "^3.1.0",
		"fuse.js": "^7.3.0",
		"gray-matter": "^4.0.3",
		"lucide-react": "^0.545.0",
		"mermaid": "^11.15.0",
		"next": "15.5.18",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"rehype-highlight": "^7.0.2",
		"rehype-raw": "^7.0.0",
		"rehype-slug": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"unified": "^11.0.5"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.1.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@eslint/eslintrc": "^3.3.1",
		"@next/bundle-analyzer": "15.5.18",
		"@tailwindcss/typography": "^0.5.10",
		"@types/node": "^20.0.0",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "8.59.4",
		"@typescript-eslint/parser": "8.59.4",
		"autoprefixer": "^10.4.16",
		"eslint": "8.57.1",
		"eslint-config-next": "15.5.18",
		"eslint-config-prettier": "^10.1.8",
		"fast-xml-parser": "^5.8.0",
		"feed": "^5.2.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.4",
		"postcss": "^8.4.31",
		"prettier": "^3.6.2",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"tailwindcss": "^3.3.5",
		"tsx": "^4.22.3",
		"typescript": "^5.0.0"
	}
}

{
	"ci": {
		"collect": {
			"numberOfRuns": 1,
			"url": [
				"http://127.0.0.1:3000/",
				"http://127.0.0.1:3000/blog.html",
				"http://127.0.0.1:3000/blog/logging/elk-ilm-strategy-guide.html"
			]
		},
		"assert": {
			"assertions": {
				"aria-progressbar-name": ["error", { "minScore": 1 }],
				"label-content-name-mismatch": ["error", { "minScore": 1 }],
				"errors-in-console": ["error", { "minScore": 1 }],
				"color-contrast": ["warn", { "minScore": 0.9 }],
				"categories:performance": ["warn", { "minScore": 0.85 }],
				"largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
				"cumulative-layout-shift": ["warn", { "maxNumericValue": 0.1 }],
				"total-byte-weight": ["warn", { "maxNumericValue": 350000 }]
			}
		},
		"upload": {
			"target": "temporary-public-storage"
		}
	}
}

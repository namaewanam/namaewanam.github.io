{
	"ci": {
		"collect": {
			"numberOfRuns": 1,
			"staticDistDir": "./out",
			"url": [
				"http://localhost/",
				"http://localhost/blog.html",
				"http://localhost/blog/logging/elk-ilm-strategy-guide.html"
			]
		},
		"assert": {
			"assertions": {
				"aria-progressbar-name": ["error", { "minScore": 1 }],
				"label-content-name-mismatch": ["error", { "minScore": 1 }],
				"errors-in-console": ["error", { "minScore": 1 }],
				"categories:performance": ["warn", { "minScore": 0.55 }],
				"largest-contentful-paint": ["warn", { "maxNumericValue": 7500 }],
				"cumulative-layout-shift": ["warn", { "maxNumericValue": 0.1 }],
				"total-byte-weight": ["warn", { "maxNumericValue": 1500000 }]
			}
		},
		"upload": {
			"target": "temporary-public-storage"
		}
	}
}

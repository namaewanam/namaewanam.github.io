# ──────────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
# .env.local is gitignored and never committed.
# ──────────────────────────────────────────────────

# Giscus — GitHub Discussions comments
# Get values at: https://giscus.app
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# Resume PDF — override to point at Google Drive
# Default: /cv.pdf (served from public/cv.pdf)
# NEXT_PUBLIC_RESUME_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=sharing
